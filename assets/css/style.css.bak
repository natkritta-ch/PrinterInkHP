:root {
    --primary: #6366f1;
    --primary-dark: #4f46e5;
    --secondary: #0ea5e9;
    --accent: #f43f5e;
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --bg-body: #f1f5f9;
    --bg-card: rgba(255, 255, 255, 0.9);
    --text-main: #0f172a;
    --text-muted: #64748b;
    --border: rgba(226, 232, 240, 0.8);
    --glass-bg: rgba(255, 255, 255, 0.82);
    --glass-border: rgba(255, 255, 255, 0.5);
    --shadow: 0 4px 24px rgba(31, 38, 135, 0.08);
    --radius: 20px;
    --nav-height: 60px;
    --tab-bar-height: 72px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

body {
    font-family: 'Outfit', 'Sarabun', sans-serif;
    background: var(--bg-body);
    color: var(--text-main);
    min-height: 100vh;
    overflow-x: hidden;
}

body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at 0% 0%, rgba(99,102,241,0.05) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(14,165,233,0.05) 0%, transparent 50%);
    pointer-events: none;
    z-index: -1;
}

/* ===== NAVIGATION ===== */
.glass-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--nav-height);
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--glass-border);
    z-index: 1000;
    display: flex;
    align-items: center;
}

.nav-content {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    padding: 0 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--primary-dark);
    text-decoration: none;
}

.nav-links { display: flex; gap: 28px; }

.nav-links a {
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
    position: relative;
    padding: 4px 0;
}
.nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 2px;
    background: var(--primary);
    transition: width 0.3s ease;
}
.nav-links a:hover, .nav-links a.active { color: var(--primary-dark); }
.nav-links a.active::after { width: 100%; }

/* ===== MAIN CONTENT ===== */
main {
    margin-top: var(--nav-height);
    padding: 24px 20px;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: 100px;
}

/* ===== BUTTONS ===== */
.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    border: none;
    padding: 11px 20px;
    border-radius: 13px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
    box-shadow: 0 6px 14px rgba(79,70,229,0.28);
    white-space: nowrap;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 20px rgba(79,70,229,0.35); }
.btn-primary:active { transform: translateY(0); }

.btn-secondary {
    background: white;
    color: var(--primary);
    border: 1.5px solid var(--primary);
    padding: 10px 18px;
    border-radius: 13px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
    white-space: nowrap;
}
.btn-secondary:hover { background: rgba(79,70,229,0.06); transform: translateY(-1px); }

.btn-danger {
    background: white;
    color: var(--danger);
    border: 1.5px solid var(--danger);
    padding: 10px 18px;
    border-radius: 13px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
    white-space: nowrap;
}
.btn-danger:hover { background: rgba(239,68,68,0.06); transform: translateY(-1px); }

/* ===== MOBILE TAB BAR ===== */
.mobile-tab-bar {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 32px);
    max-width: 420px;
    height: var(--tab-bar-height);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 36px;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    z-index: 1000;
}

.tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.65rem;
    font-weight: 500;
    gap: 3px;
    flex: 1;
    padding: 6px 0;
    border-radius: 16px;
    transition: all 0.25s;
}
.tab-item.active {
    color: var(--primary-dark);
    background: rgba(99,102,241,0.08);
}
.tab-icon { font-size: 1.3rem; line-height: 1; }
.tab-label { line-height: 1; }

/* Scan FAB */
.scan-fab-container { position: relative; width: 56px; height: 56px; flex-shrink: 0; }
.scan-fab {
    position: absolute;
    top: -32px; left: 0;
    width: 56px; height: 56px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.4rem;
    border: 3px solid var(--bg-body);
    box-shadow: 0 8px 18px rgba(79,70,229,0.4);
    cursor: pointer;
    transition: all 0.25s;
}
.scan-fab:hover { transform: scale(1.08) rotate(5deg); }

/* ===== CARDS ===== */
.card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 20px;
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.25s ease;
}
.card:hover { transform: translateY(-3px); }

.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}

/* ===== BADGES ===== */
.badge {
    padding: 5px 12px;
    border-radius: 30px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.3px;
}
.badge-normal    { background: rgba(16,185,129,0.12); color: var(--success); }
.badge-repairing { background: rgba(245,158,11,0.12); color: var(--warning); }
.badge-broken    { background: rgba(239,68,68,0.12);  color: var(--danger); }

/* ===== MODAL ===== */
.modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 2000;
    overflow: hidden; /* Prevent scrolling the wrapper */
    padding: 16px;
    animation: fadeIn 0.25s ease;
    align-items: center;
    justify-content: center;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}

.modal-content {
    position: relative;
    width: 100%;
    max-width: 520px;
    background: white;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.18);
    display: flex;
    flex-direction: column;
    max-height: 90vh; /* Don't exceed screen height */
    overflow: hidden;
    animation: modalSlideUp 0.35s cubic-bezier(0.4,0,0.2,1);
}

@keyframes modalSlideUp {
    from { transform: translateY(24px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}

.modal-lg { max-width: 900px; }

.modal-header {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    z-index: 10;
    flex-shrink: 0;
}
.modal-header h3 { margin: 0; font-size: 1.15rem; color: var(--text-main); }

.modal-body { 
    padding: 20px 24px; 
    overflow-y: auto; /* Internal scroll */
    flex: 1;
}

.close-modal-btn {
    background: var(--bg-body);
    border: none;
    width: 34px; height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1.1rem;
    color: var(--text-muted);
    flex-shrink: 0;
}
.close-modal-btn:hover { background: #fee2e2; color: var(--danger); transform: rotate(90deg); }

/* ===== SCANNER ===== */
#reader { width: 100% !important; border: none !important; }
#reader__scan_region { background: #000; border-radius: 16px; }

/* ===== TYPOGRAPHY ===== */
h1 { font-size: 1.5rem; font-weight: 700; color: var(--text-main); margin-bottom: 4px; }
h2 { font-size: 1.15rem; font-weight: 700; color: var(--text-main); margin-bottom: 4px; }
h3 { font-size: 1rem; font-weight: 700; color: var(--text-main); margin-bottom: 4px; }

/* ===== LOADER ===== */
.loader-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 50vh;
}
.loader {
    width: 44px; height: 44px;
    border: 4px solid #e2e8f0;
    border-bottom-color: var(--primary);
    border-radius: 50%;
    animation: rotation 0.9s linear infinite;
}
@keyframes rotation { 100% { transform: rotate(360deg); } }

/* ===== SEARCHABLE SELECT ===== */
.searchable-select { position: relative; }
.select-dropdown {
    position: absolute;
    top: calc(100% + 6px); left: 0;
    width: 100%;
    max-height: 240px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.12);
    border: 1px solid var(--border);
    overflow-y: auto;
    z-index: 1000;
    display: none;
    animation: dropdownIn 0.18s ease;
}
@keyframes dropdownIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
}
.select-item { padding: 11px 18px; cursor: pointer; font-size: 0.92rem; color: var(--text-main); transition: background 0.15s; }
.select-item:hover { background: var(--bg-body); color: var(--primary); }
.select-item.hidden { display: none; }

/* ===== PAGE HEADER UTILITY ===== */
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
    gap: 12px;
}
.page-header-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex-shrink: 0;
}

/* ===== PRINTER CARDS GRID (Mobile-first) ===== */
.printer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    padding: 16px;
}
.printer-card {
    height: fit-content;
    display: flex;
    flex-direction: column;
    min-height: 100px;
}

/* ===== DEPT HEADER (Mobile) ===== */
.dept-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 8px;
}
.dept-stats {
    display: flex;
    gap: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    flex-wrap: wrap;
}

/* ===== FORM ELEMENTS ===== */
input, select, textarea {
    font-family: inherit;
}
.form-group { margin-bottom: 16px; }
.form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; }
.form-input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border 0.2s;
    background: white;
}
.form-input:focus { border-color: var(--primary); }

/* ===== DESKTOP OVERRIDES ===== */
@media (min-width: 769px) {
    .mobile-only { display: none !important; }

    main {
        padding: 32px 28px 100px;
        margin-top: var(--nav-height);
    }
    h1 { font-size: 1.75rem; }

    .printer-grid {
        grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
        gap: 16px;
        padding: 20px 24px;
    }
    .dept-header { padding: 16px 24px; }
}

/* ===== MOBILE OVERRIDES ===== */
@media (max-width: 768px) {
    .desktop-only { display: none !important; }

    .nav-content { justify-content: center; }
    .logo { font-size: 1.2rem; }

    main {
        padding: 16px 12px 110px;
        margin-top: var(--nav-height);
    }

    h1 { font-size: 1.3rem; }
    h2 { font-size: 1rem; }

    .dashboard-grid { grid-template-columns: 1fr; gap: 14px; }

    .card { padding: 16px; border-radius: 18px; }

    /* Page header stacks on mobile */
    .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    .page-header-actions {
        width: 100%;
        justify-content: flex-start;
    }
    .page-header-actions .btn-primary,
    .page-header-actions .btn-secondary,
    .page-header-actions .btn-danger {
        flex: 1;
        justify-content: center;
        font-size: 0.82rem;
        padding: 9px 10px;
    }

    /* Printer grid: 2 columns on phone */
    .printer-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        padding: 12px;
    }

    /* Modal alignment for mobile (bottom sheet) */
    .modal {
        padding: 0;
        align-items: flex-end;
        justify-content: center;
    }
    
    /* Ensure modals shown via JS (style.display) are flex containers on mobile */
    .modal[style*="display: block"],
    .modal[style*="display: flex"] {
        display: flex !important;
    }
    
    .modal-content {
        width: 100%;
        max-width: none;
        margin: 0;
        border-radius: 28px 28px 0 0;
        max-height: 92vh; /* Ensure some space at top to see backdrop/click out */
        animation: slideFromBottom 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    @keyframes slideFromBottom {
        from { transform: translateY(100%); opacity: 0.5; }
        to   { transform: translateY(0);    opacity: 1; }
    }
}

/* ===== SMALL SCREEN (≤ 380px) ===== */
@media (max-width: 380px) {
    .printer-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; padding: 10px; }
    .tab-label { display: none; }
    .tab-item { padding: 8px 0; }
}
